# Secrets - NEVER COMMIT THESE
*.key
*.pem
.env
.env.*
secrets.json
credentials.json
*_credentials.json
*_secret*.json

# Config with secrets - use template instead
openclaw.json

# Personal/sensitive memory (workspace runtime files)
# Note: roles/*/files/MEMORY.md is a TEMPLATE and SHOULD be committed
!ansible/roles/*/files/MEMORY.md
memory/
*.memory.json

# Delivery queues and logs
delivery-queue/
logs/
*.log
*.tmp

# Node modules
node_modules/
package-lock.json

# Artifacts and temp files
artifacts/
tmp/

# Browser/cache
browser/
canvas/

# Telegram session data
telegram/

# Git directory from workspace
.git/

# Credentials folder
credentials/

# Devices
devices/

# Identity sensitive files
identity/

# Ansible vault password file - NEVER commit
.vault_password*

# GCP service account keys
**/gcp-sa-key.json
**/*-sa-key.json

# Host-specific secrets (bot tokens per worker)
**/inventory/*/host_vars/

# NOTE: vault.yml files ARE committed because they are ansible-vault ENCRYPTED.
# The vault password file (~/.ansible/vault_password) is what must NEVER be committed.
