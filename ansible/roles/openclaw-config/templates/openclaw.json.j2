{
  "meta": {
    "lastTouchedVersion": "2026.3.2"
  },
  "agents": {
    "defaults": {
      "model": "{{ openclaw_model }}",
      "workspace": "{{ openclaw_workspace }}"
    },
    "list": [
      {
        "id": "main",
        "name": "main",
        "workspace": "{{ openclaw_workspace }}"
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "{{ telegram_bot_token }}",
      "allowFrom": {{ telegram_allowed_users | to_json }},
      "groupPolicy": "open"
    }
  },
  "gateway": {
    "port": {{ gateway_port }},
    "mode": "{{ gateway_mode }}",
    "bind": "{{ gateway_bind }}",
    "auth": {
      "mode": "token",
      "token": "{{ gateway_token }}"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:{{ gateway_port }}",
        "http://127.0.0.1:{{ gateway_port }}",
        "http://{{ ansible_default_ipv4.address }}:{{ gateway_port }}"
      ]
    }
  }
}