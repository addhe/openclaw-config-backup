# Ansible
*.retry
*.log

# Vault password files - NEVER COMMIT
.vault_password_staging
.vault_password_production
.vault_password
.vault_password_*

# Decrypted vault files (should not exist, but just in case)
*.dec

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/

# Ansible collections (installed locally)
collections/

# Temporary files
*.tmp
*.bak
*.swp
*~

# IDE
.idea/
.vscode/
*.sublime-*

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Credentials - NEVER COMMIT
*.key
*.pem
credentials/
service-account*.json
gcp-sa-key.json
*.json
